# Persistent token store — OPTIONAL locally, REQUIRED in production for iSolarCloud.
# When set, OAuth tokens are stored in Postgres (e.g. Neon) instead of token_store.json,
# so they survive restarts / ephemeral filesystems. Leave blank for local file storage.
# Example: postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require
DATABASE_URL=

# iSolarCloud / Sungrow inverter API (OAuth2 authorization code) — OPTIONAL.
# If any of app_key / secret_key / app_id is missing, solar endpoints are
# disabled and the rest of the dashboard runs normally.
app_key=
secret_key=
app_id=
# redirect_uri defaults to http://localhost:8000/api/solar/auth/callback if unset.
redirect_uri=
# ISOLAR_SERVER defaults to "Australia" if unset.
ISOLAR_SERVER=Australia

# Google SSO — gates the whole dashboard behind COG Google accounts.
# From Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Signs the session cookie. Generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
# If unset, an ephemeral secret is used and sessions reset on every restart.
SESSION_SECRET=
# Only verified accounts in this Google Workspace domain may sign in.
ALLOWED_DOMAIN=cognz.com
# Optional extra allowlist of individual addresses (comma-separated). Honoured in
# addition to ALLOWED_DOMAIN. If BOTH this and ALLOWED_DOMAIN are empty, nobody
# can sign in (the gate fails closed).
ALLOWED_EMAILS=
# Base URL used to build the OAuth redirect URI and set the cookie Secure flag.
# Local dev: http://localhost:5173 (Vite origin; it proxies /api to the backend).
# Production: https://cog-dashboard.onrender.com
PUBLIC_BASE_URL=http://localhost:5173
